<div class="skills-step">

    <div class="skills-step-header">
        <div>
            <MudText Typo="Typo.h5">Occupation &amp; Skills</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                Choose your investigator's occupation and allocate skill points.
            </MudText>
        </div>
    </div>

    @* ── Occupation selection ─────────────────────── *@
    <div class="occupation-section">
        <MudText Typo="Typo.h6">Occupation</MudText>

        <div class="occupation-picker-row">
            <MudAutocomplete T="Occupation"
                             Value="_selectedOccupation"
                             ValueChanged="OnOccupationSelected"
                             SearchFunc="@((string query, CancellationToken _) =>
                                 Task.FromResult(Data.Occupations.All
                                     .Where(o => string.IsNullOrWhiteSpace(query) || o.Name.Contains(query, StringComparison.OrdinalIgnoreCase))
                                     .AsEnumerable()))"
                             ToStringFunc="@(o => o?.Name ?? string.Empty)"
                             Label="Select Occupation"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Dense="true"
                             Class="occupation-autocomplete" />
            @if (_selectedOccupation is not null)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Clear"
                               Size="Size.Small"
                               Color="Color.Default"
                               OnClick="ClearOccupation" />
            }
        </div>

        @if (_selectedOccupation is not null)
        {
            <div class="occupation-details">
                <div class="occupation-detail-row">
                    <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">
                        <strong>Skill Points:</strong> @SkillPointsFormula = <strong>@OccupationSkillPoints</strong>
                    </MudText>
                </div>
                <div class="occupation-detail-row">
                    <MudIcon Icon="@Icons.Material.Filled.CreditCard" Size="Size.Small" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">
                        <strong>Credit Rating:</strong> @_selectedOccupation.CreditRatingMin–@_selectedOccupation.CreditRatingMax%
                    </MudText>
                </div>
                <div class="occupation-detail-row">
                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">
                        <strong>Contacts:</strong> @string.Join(", ", _selectedOccupation.SuggestedContacts)
                    </MudText>
                </div>
                <div class="occupation-skills-chips">
                    @foreach (var skillName in _selectedOccupation.Skills)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary">@skillName</MudChip>
                    }
                </div>
            </div>
        }
    </div>

    @* ── Skills list ──────────────────────────────── *@
    <div class="skills-step-toolbar">
        <MudTextField @bind-Value="_skillFilter"
                      Placeholder="Filter skills..."
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Class="skills-step-filter"
                      Immediate="true"
                      Clearable="true" />
        <MudButton Variant="Variant.Outlined"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.FormatListBulleted"
                   OnClick="LoadDefaultSkills">
            Load Defaults
        </MudButton>
        <MudIconButton Icon="@Icons.Material.Filled.Add"
                       Color="Color.Primary"
                       Size="Size.Small"
                       OnClick="AddSkill" />
    </div>

    @{
        var skillList = FilteredSkills.ToList();
        var half = (skillList.Count + 1) / 2;
        var leftSkills = skillList.Take(half).ToList();
        var rightSkills = skillList.Skip(half).ToList();
    }

    @if (skillList.Count > 0)
    {
        <div class="skill-step-columns">
            @foreach (var columnSkills in new[] { leftSkills, rightSkills })
            {
                <div class="skill-step-grid">
                    <span class="skill-step-col-header">Skill</span>
                    <span class="skill-step-col-header skill-step-col-center">Base</span>
                    <span></span>
                    @foreach (var skill in columnSkills)
                    {
                        var isOccSkill = IsOccupationSkill(skill);
                        <div class="skill-step-name-cell @(isOccSkill ? "skill-step-occupation" : "")">
                            <MudTextField @bind-Value="skill.Name"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />
                            @if (isOccSkill)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Star"
                                         Size="Size.Small"
                                         Color="Color.Primary"
                                         Class="skill-step-star" />
                            }
                        </div>
                        <MudNumericField T="int"
                                         @bind-Value="skill.BaseValue"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         HideSpinButtons="true" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="() => RemoveSkill(skill)" />
                    }
                </div>
            }
        </div>
    }
    else
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
            No skills yet. Click <strong>Load Defaults</strong> or <strong>+</strong> to add skills.
        </MudText>
    }

</div>
