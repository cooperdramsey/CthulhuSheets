<div class="skills-step">

    <div class="skills-step-header">
        <div>
            <MudText Typo="Typo.h5">Occupation &amp; Skills</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                Choose your investigator's occupation and allocate skill points.
            </MudText>
        </div>
    </div>

    @* ── Occupation selection ─────────────────────── *@
    <div class="occupation-section">
        <div class="occupation-header-row">
            <MudText Typo="Typo.h6">Occupation</MudText>
            <MudButton Variant="Variant.Text"
                       Size="Size.Small"
                       StartIcon="@(_isCustomOccupation ? Icons.Material.Filled.List : Icons.Material.Filled.Edit)"
                       OnClick="ToggleCustomOccupation">
                @(_isCustomOccupation ? "Select Preset" : "Create Custom")
            </MudButton>
        </div>

        @if (_isCustomOccupation)
        {
            @if (_customOccupationConfirmed)
            {
                <div class="occupation-confirmed-header">
                    <MudText Typo="Typo.subtitle1"><strong>@_customOccupationName</strong></MudText>
                    <MudButton Variant="Variant.Text"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="EditCustomOccupation">
                        Edit
                    </MudButton>
                </div>
                <div class="occupation-details">
                    <div class="occupation-detail-row">
                        <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">
                            <strong>Skill Points:</strong> @SkillPointsFormula = <strong>@OccupationSkillPoints</strong>
                        </MudText>
                    </div>
                    <div class="occupation-detail-row">
                        <MudIcon Icon="@Icons.Material.Filled.CreditCard" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">
                            <strong>Credit Rating:</strong> @_customCreditRatingMin–@_customCreditRatingMax%
                        </MudText>
                    </div>
                    <div class="occupation-skills-chips">
                        @foreach (var skillName in _occupationSkillNames)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary">@skillName</MudChip>
                        }
                    </div>
                </div>
            }
            else
            {
                <MudTextField T="string"
                              Value="_customOccupationName"
                              ValueChanged="OnCustomNameChanged"
                              Label="Occupation Name"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Immediate="true" />

                <div class="custom-credit-row">
                    <MudNumericField T="int"
                                     Value="_customCreditRatingMin"
                                     ValueChanged="OnCustomCreditMinChanged"
                                     Label="Credit Rating Min"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="0" Max="99"
                                     HideSpinButtons="true" />
                    <MudText Typo="Typo.body1" Class="custom-credit-separator">–</MudText>
                    <MudNumericField T="int"
                                     Value="_customCreditRatingMax"
                                     ValueChanged="OnCustomCreditMaxChanged"
                                     Label="Credit Rating Max"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="0" Max="99"
                                     HideSpinButtons="true" />
                </div>

                <div class="custom-formula-section">
                    <MudText Typo="Typo.subtitle2">Skill Point Formula</MudText>
                    @for (var i = 0; i < _customFormulas.Count; i++)
                    {
                        var index = i;
                        <div class="custom-formula-row">
                            <MudSelect T="string"
                                       Value="_customFormulas[index].Characteristic"
                                       ValueChanged="@(v => OnFormulaCharacteristicChanged(index, v))"
                                       Label="Stat"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Dense="true"
                                       Class="custom-formula-select">
                                @foreach (var c in AvailableCharacteristics)
                                {
                                    <MudSelectItem T="string" Value="c">@c</MudSelectItem>
                                }
                            </MudSelect>
                            <MudText Typo="Typo.body1">×</MudText>
                            <MudNumericField T="int"
                                             Value="_customFormulas[index].Multiplier"
                                             ValueChanged="@(v => OnFormulaMultiplierChanged(index, v))"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             Min="1" Max="4"
                                             HideSpinButtons="true"
                                             Class="custom-formula-multiplier" />
                            @if (_customFormulas.Count > 1)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="() => RemoveFormulaSlot(index)" />
                            }
                        </div>
                    }
                    <MudButton Variant="Variant.Text"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="AddFormulaSlot">
                        Add Stat
                    </MudButton>
                </div>

                <div class="occupation-details">
                    <div class="occupation-detail-row">
                        <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">
                            <strong>Skill Points:</strong> @SkillPointsFormula = <strong>@OccupationSkillPoints</strong>
                        </MudText>
                    </div>
                    <div class="occupation-detail-row">
                        <MudIcon Icon="@Icons.Material.Filled.TouchApp" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">
                            <strong>Occupation Skills:</strong> @_occupationSkillNames.Count / 8 — click ★ on skills below to select
                        </MudText>
                    </div>
                </div>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="ConfirmCustomOccupation"
                           Disabled="!CanConfirmCustomOccupation"
                           StartIcon="@Icons.Material.Filled.Check"
                           Class="mt-2">
                    Confirm Occupation
                </MudButton>
            }
        }
        else
        {
            <div class="occupation-picker-row">
                <MudAutocomplete T="Occupation"
                                 Value="_selectedOccupation"
                                 ValueChanged="OnOccupationSelected"
                                 SearchFunc="@((string query, CancellationToken _) =>
                                     Task.FromResult(Data.Occupations.All
                                         .Where(o => string.IsNullOrWhiteSpace(query) || o.Name.Contains(query, StringComparison.OrdinalIgnoreCase))
                                         .AsEnumerable()))"
                                 ToStringFunc="@(o => o?.Name ?? string.Empty)"
                                 Label="Select Occupation"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Dense="true"
                                 Class="occupation-autocomplete" />
                @if (_selectedOccupation is not null)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="ClearOccupation" />
                }
            </div>

            @if (_selectedOccupation is not null)
            {
                <div class="occupation-details">
                    <div class="occupation-detail-row">
                        <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">
                            <strong>Skill Points:</strong> @SkillPointsFormula = <strong>@OccupationSkillPoints</strong>
                        </MudText>
                    </div>
                    <div class="occupation-detail-row">
                        <MudIcon Icon="@Icons.Material.Filled.CreditCard" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">
                            <strong>Credit Rating:</strong> @_selectedOccupation.CreditRatingMin–@_selectedOccupation.CreditRatingMax%
                        </MudText>
                    </div>
                    <div class="occupation-detail-row">
                        <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">
                            <strong>Contacts:</strong> @string.Join(", ", _selectedOccupation.SuggestedContacts)
                        </MudText>
                    </div>
                    <div class="occupation-skills-chips">
                        @foreach (var skillName in _selectedOccupation.Skills)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary">@skillName</MudChip>
                        }
                    </div>
                </div>
            }
        }
    </div>

    @* ── Point pool summary ────────────────────────── *@
    @if (IsOccupationConfirmed)
    {
        <div class="pool-summary">
            <div class="pool-summary-row">
                <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Primary" />
                <MudText Typo="Typo.body2">
                    <strong>Occupation:</strong> @SkillPointsFormula = @OccupationSkillPoints
                </MudText>
                <MudChip T="string" Size="Size.Small"
                         Color="@(PointsRemaining == 0 ? Color.Success : PointsRemaining < 0 ? Color.Error : Color.Warning)">
                    @PointsRemaining remaining
                </MudChip>
            </div>
            <div class="pool-summary-row">
                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Secondary" />
                <MudText Typo="Typo.body2">
                    <strong>Personal Interest:</strong> INT × 2 = @PersonalInterestPoints
                </MudText>
                <MudChip T="string" Size="Size.Small"
                         Color="@(PersonalPointsRemaining == 0 ? Color.Success : PersonalPointsRemaining < 0 ? Color.Error : Color.Warning)">
                    @PersonalPointsRemaining remaining
                </MudChip>
            </div>
            @if (PointsRemaining < 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Error">
                    Occupation points over-allocated by @Math.Abs(PointsRemaining).
                </MudText>
            }
            @if (PersonalPointsRemaining < 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Error">
                    Personal points over-allocated by @Math.Abs(PersonalPointsRemaining).
                </MudText>
            }
            @if (CreditRatingGrandTotal < (_selectedOccupation?.CreditRatingMin ?? 0))
            {
                <MudText Typo="Typo.caption" Color="Color.Error">
                    Credit Rating must be at least @(_selectedOccupation!.CreditRatingMin)% (currently @CreditRatingGrandTotal%).
                </MudText>
            }
            @if (CreditRatingGrandTotal > (_selectedOccupation?.CreditRatingMax ?? 99))
            {
                <MudText Typo="Typo.caption" Color="Color.Error">
                    Credit Rating cannot exceed @(_selectedOccupation!.CreditRatingMax)% (currently @CreditRatingGrandTotal%).
                </MudText>
            }
        </div>
    }

    @* ── Skills list ──────────────────────────────── *@
    <div class="skills-step-toolbar">
        <MudTextField @bind-Value="_skillFilter"
                      Placeholder="Filter skills..."
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Class="skills-step-filter"
                      Immediate="true"
                      Clearable="true" />
        <MudButton Variant="Variant.Outlined"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.FormatListBulleted"
                   OnClick="LoadDefaultSkills">
            Load Defaults
        </MudButton>
        <MudIconButton Icon="@Icons.Material.Filled.Add"
                       Color="Color.Primary"
                       Size="Size.Small"
                       OnClick="AddSkill" />
    </div>

    @{
        var skillList = FilteredSkills.ToList();
    }

    @if (skillList.Count > 0)
    {
        @if (IsOccupationConfirmed)
        {
            <div class="skill-step-grid-inline">
                <span class="skill-step-col-header">Skill</span>
                <span class="skill-step-col-header skill-step-col-center">Base</span>
                <span class="skill-step-col-header skill-step-col-center">Occ.</span>
                <span class="skill-step-col-header skill-step-col-center">Personal</span>
                <span class="skill-step-col-header skill-step-col-center">Total</span>
                <span></span>

                @foreach (var skill in skillList)
                {
                    var isOccSkill = IsOccupationSkill(skill);
                    var isCthulhu = skill.Name.Equals("Cthulhu Mythos", StringComparison.OrdinalIgnoreCase);
                    var occAlloc = _allocations.GetValueOrDefault(skill.Name);
                    var personalAlloc = _personalAllocations.GetValueOrDefault(skill.Name);
                    var total = skill.BaseValue + occAlloc + personalAlloc;
                    var isCR = skill.Name.Equals("Credit Rating", StringComparison.OrdinalIgnoreCase);
                    var capVal = isCR ? (_selectedOccupation?.CreditRatingMax ?? 99) : 75;

                    <div class="skill-step-name-cell @(isOccSkill ? "skill-step-occupation" : "")">
                        <MudTextField @bind-Value="skill.Name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                        @if (isOccSkill)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Star"
                                     Size="Size.Small"
                                     Color="Color.Primary"
                                     Class="skill-step-star" />
                        }
                    </div>
                    <MudNumericField T="int"
                                     @bind-Value="skill.BaseValue"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="true"
                                     ReadOnly="true" />
                    @if (isOccSkill && !isCthulhu)
                    {
                        <MudNumericField T="int"
                                         Value="occAlloc"
                                         ValueChanged="@(v => OnAllocationChanged(skill.Name, v))"
                                         Min="0"
                                         Max="@GetMaxAllocation(skill.Name)"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         HideSpinButtons="true"
                                         Class="allocation-input" />
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Tertiary">—</MudText>
                    }
                    @if (!isCthulhu)
                    {
                        <MudNumericField T="int"
                                         Value="personalAlloc"
                                         ValueChanged="@(v => OnPersonalAllocationChanged(skill.Name, v))"
                                         Min="0"
                                         Max="@GetMaxPersonalAllocation(skill.Name)"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         HideSpinButtons="true"
                                         Class="allocation-input" />
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Tertiary">—</MudText>
                    }
                    <MudText Typo="Typo.body2" Align="Align.Center"
                             Color="@(total > capVal ? Color.Error : Color.Default)">
                        <strong>@total</strong>
                    </MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="() => RemoveSkill(skill)" />
                }
            </div>
        }
        else
        {
            var half = (skillList.Count + 1) / 2;
            var leftSkills = skillList.Take(half).ToList();
            var rightSkills = skillList.Skip(half).ToList();
            <div class="skill-step-columns">
                @foreach (var columnSkills in new[] { leftSkills, rightSkills })
                {
                    <div class="skill-step-grid">
                        <span class="skill-step-col-header">Skill</span>
                        <span class="skill-step-col-header skill-step-col-center">Base</span>
                        <span></span>
                        @foreach (var skill in columnSkills)
                        {
                            var isOccSkill = IsOccupationSkill(skill);
                            <div class="skill-step-name-cell @(isOccSkill ? "skill-step-occupation" : "")">
                                <MudTextField @bind-Value="skill.Name"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                                @if (_isCustomOccupation && !_customOccupationConfirmed)
                                {
                                    <MudIconButton Icon="@(isOccSkill ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)"
                                                   Size="Size.Small"
                                                   Color="@(isOccSkill ? Color.Primary : Color.Default)"
                                                   OnClick="() => ToggleOccupationSkill(skill)"
                                                   Class="skill-step-star" />
                                }
                                else if (isOccSkill)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Star"
                                             Size="Size.Small"
                                             Color="Color.Primary"
                                             Class="skill-step-star" />
                                }
                            </div>
                            <MudNumericField T="int"
                                             @bind-Value="skill.BaseValue"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             HideSpinButtons="true"
                                             ReadOnly="true" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="() => RemoveSkill(skill)" />
                        }
                    </div>
                }
            </div>
        }
    }
    else
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
            No skills yet. Click <strong>Load Defaults</strong> or <strong>+</strong> to add skills.
        </MudText>
    }

</div>
