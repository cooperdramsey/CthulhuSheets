<div class="combat-container">
    <div class="combat-stats-bar">
        <div class="combat-stat-chip">
            <div class="combat-stat-label">
                <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" Color="Color.Primary" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">Build</MudText>
            </div>
            <MudText Typo="Typo.h5" Class="combat-stat-value">@(Investigator.Build?.ToString() ?? "—")</MudText>
        </div>
        <div class="combat-stat-chip">
            <div class="combat-stat-label">
                <MudIcon Icon="@Icons.Material.Filled.FitnessCenter" Size="Size.Small" Color="Color.Tertiary" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">Damage Bonus</MudText>
            </div>
            <MudText Typo="Typo.h5" Class="combat-stat-value">@(Investigator.DamageBonus ?? "—")</MudText>
        </div>
        <div class="combat-stat-chip">
            <div class="combat-stat-label">
                <MudIcon Icon="@Icons.Material.Filled.DirectionsRun" Size="Size.Small" Color="Color.Warning" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">Move</MudText>
            </div>
            <MudText Typo="Typo.h5" Class="combat-stat-value">@(Investigator.MovementRate?.ToString() ?? "—")</MudText>
        </div>
        <div class="combat-stat-chip combat-stat-chip--dodge">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Dodge</MudText>
            <div class="combat-dodge-row">
                <div class="combat-dodge-tier">
                    <span class="combat-dodge-num">@(DodgeRegular?.ToString() ?? "—")</span>
                    @if (_dodgeRoll.HasValue && DodgeRegular.HasValue)
                    {
                        <MudIcon Icon="@(_dodgeRoll <= DodgeRegular ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)"
                                 Color="@(_dodgeRoll <= DodgeRegular ? Color.Success : Color.Error)"
                                 Size="Size.Small" Class="roll-check-icon" />
                    }
                    <span class="combat-dodge-label">Reg</span>
                </div>
                <span class="combat-dodge-sep">/</span>
                <div class="combat-dodge-tier">
                    <span class="combat-dodge-num">@(DodgeHard?.ToString() ?? "—")</span>
                    @if (_dodgeRoll.HasValue && DodgeHard.HasValue)
                    {
                        <MudIcon Icon="@(_dodgeRoll <= DodgeHard ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)"
                                 Color="@(_dodgeRoll <= DodgeHard ? Color.Success : Color.Error)"
                                 Size="Size.Small" Class="roll-check-icon" />
                    }
                    <span class="combat-dodge-label">Hard</span>
                </div>
                <span class="combat-dodge-sep">/</span>
                <div class="combat-dodge-tier">
                    <span class="combat-dodge-num">@(DodgeExtreme?.ToString() ?? "—")</span>
                    @if (_dodgeRoll.HasValue && DodgeExtreme.HasValue)
                    {
                        <MudIcon Icon="@(_dodgeRoll <= DodgeExtreme ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)"
                                 Color="@(_dodgeRoll <= DodgeExtreme ? Color.Success : Color.Error)"
                                 Size="Size.Small" Class="roll-check-icon" />
                    }
                    <span class="combat-dodge-label">Ext</span>
                </div>
            </div>
            <div class="roll-action">
                <MudTooltip Text="Roll d100">
                    <MudIconButton Icon="@Icons.Material.Filled.Casino"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="RollDodge" />
                </MudTooltip>
                <span class="roll-result">@(_dodgeRoll?.ToString() ?? "")</span>
            </div>
        </div>
    </div>
    <div class="combat-weapons-section">
        <div class="combat-weapons-header">
            <MudText Typo="Typo.h6">Weapons</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Add"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="AddWeapon" />
        </div>
        @if (Investigator.Weapons.Count > 0)
        {
            <div class="weapon-grid">
                <span class="weapon-col-header">Name</span>
                <span class="weapon-col-header">Damage</span>
                <span class="weapon-col-header">Atk/Rnd</span>
                <span class="weapon-col-header">Range</span>
                <span class="weapon-col-header">Ammo</span>
                <span class="weapon-col-header">Malf</span>
                <span></span>
                @foreach (var weapon in Investigator.Weapons)
                {
                    <MudTextField @bind-Value="weapon.Name"
                                  @bind-Value:after="PersistAsync"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="Name" />
                    <MudTextField @bind-Value="weapon.Damage"
                                  @bind-Value:after="PersistAsync"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="e.g. 1d6+db" />
                    <MudNumericField T="int?"
                                     @bind-Value="weapon.NumberOfAttacks"
                                     @bind-Value:after="PersistAsync"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="true" />
                    <MudTextField @bind-Value="weapon.Range"
                                  @bind-Value:after="PersistAsync"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="e.g. Touch" />
                    <MudNumericField T="int?"
                                     @bind-Value="weapon.Ammo"
                                     @bind-Value:after="PersistAsync"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="true" />
                    <MudNumericField T="int?"
                                     @bind-Value="weapon.Malfunction"
                                     @bind-Value:after="PersistAsync"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="true" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="() => RemoveWeapon(weapon)" />
                }
            </div>
        }
    </div>
</div>
