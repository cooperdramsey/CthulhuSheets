<div class="wealth-container">
    @{
        var cr = CreditRating;
    }
    @if (cr is not null)
    {
        <div class="wealth-credit-rating">
            <div class="credit-rating-chip">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Credit Rating</MudText>
                <div class="credit-rating-tiers">
                    <div class="credit-rating-tier">
                        <span class="credit-rating-num">@(cr.Regular?.ToString() ?? "—")</span>
                        @if (_creditRatingRoll.HasValue && cr.Regular.HasValue)
                        {
                            <MudIcon Icon="@(_creditRatingRoll <= cr.Regular ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)"
                                     Color="@(_creditRatingRoll <= cr.Regular ? Color.Success : Color.Error)"
                                     Size="Size.Small" Class="roll-check-icon" />
                        }
                        <span class="credit-rating-label">Reg</span>
                    </div>
                    <span class="credit-rating-sep">/</span>
                    <div class="credit-rating-tier">
                        <span class="credit-rating-num">@(cr.Half?.ToString() ?? "—")</span>
                        @if (_creditRatingRoll.HasValue && cr.Half.HasValue)
                        {
                            <MudIcon Icon="@(_creditRatingRoll <= cr.Half ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)"
                                     Color="@(_creditRatingRoll <= cr.Half ? Color.Success : Color.Error)"
                                     Size="Size.Small" Class="roll-check-icon" />
                        }
                        <span class="credit-rating-label">Hard</span>
                    </div>
                    <span class="credit-rating-sep">/</span>
                    <div class="credit-rating-tier">
                        <span class="credit-rating-num">@(cr.Fifth?.ToString() ?? "—")</span>
                        @if (_creditRatingRoll.HasValue && cr.Fifth.HasValue)
                        {
                            <MudIcon Icon="@(_creditRatingRoll <= cr.Fifth ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)"
                                     Color="@(_creditRatingRoll <= cr.Fifth ? Color.Success : Color.Error)"
                                     Size="Size.Small" Class="roll-check-icon" />
                        }
                        <span class="credit-rating-label">Ext</span>
                    </div>
                </div>
                <div class="roll-action">
                    <MudTooltip Text="Roll d100">
                        <MudIconButton Icon="@Icons.Material.Filled.Casino"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="RollCreditRating" />
                    </MudTooltip>
                    <span class="roll-result">@(_creditRatingRoll?.ToString() ?? "")</span>
                </div>
            </div>
        </div>
    }
    <div class="wealth-stats">
        <MudNumericField T="int?"
                         @bind-Value="Investigator.Wealth.SpendingLevel"
                         @bind-Value:after="PersistAsync"
                         Label="Spending Level"
                         Variant="Variant.Outlined"
                         HideSpinButtons="true" />
        <MudNumericField T="int?"
                         @bind-Value="Investigator.Wealth.Cash"
                         @bind-Value:after="PersistAsync"
                         Label="Cash"
                         Variant="Variant.Outlined"
                         HideSpinButtons="true" />
    </div>
    <div class="wealth-assets-section">
        <div class="wealth-assets-header">
            <MudText Typo="Typo.h6">Assets</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Add"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="AddAsset" />
        </div>
        @for (int i = 0; i < Investigator.Wealth.Assets.Count; i++)
        {
            var index = i;
            <div class="asset-row">
                <MudTextField Value="Investigator.Wealth.Assets[index]"
                              ValueChanged="async (string v) => { Investigator.Wealth.Assets[index] = v; await PersistAsync(); }"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Placeholder="Asset"
                              Class="asset-field" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="() => RemoveAsset(index)" />
            </div>
        }
    </div>
</div>
