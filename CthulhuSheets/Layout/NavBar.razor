<MudAppBar Color="Color.Primary" Fixed="true" Dense="true">
    <MudText Typo="Typo.h5" Class="mr-4">CthulhuSheets</MudText>
    <MudSpacer />
    <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Inherit"
                   OnClick="OnCreateNewCharacter" Title="Create New Character" />
    <MudFileUpload T="IBrowserFile" FilesChanged="HandleFileSelected" Accept=".json" Class="ml-2">
        <CustomContent>
            <MudIconButton Icon="@Icons.Material.Filled.FileUpload" Color="Color.Inherit"
                           OnClick="@context.OpenFilePickerAsync" Title="Upload Character" />
        </CustomContent>
        <SelectedTemplate />
    </MudFileUpload>
    <MudIconButton Icon="@Icons.Material.Filled.FileDownload" Color="Color.Inherit"
                   OnClick="OnFileDownload" Class="ml-2" Title="Download" />
</MudAppBar>

@code {
    [Parameter]
    public EventCallback OnCreateNewCharacter { get; set; }

    [Parameter]
    public EventCallback<IBrowserFile> OnFileSelected { get; set; }

    [Parameter]
    public EventCallback OnFileDownload { get; set; }

    private async Task HandleFileSelected(IBrowserFile file) =>
        await OnFileSelected.InvokeAsync(file);
}