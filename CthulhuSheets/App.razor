<MudThemeProvider Theme="_theme"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)"/>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
</Router>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = Colors.DeepPurple.Default,
            PrimaryDarken = Colors.DeepPurple.Darken1,
            PrimaryLighten = Colors.DeepPurple.Lighten1,
            Tertiary = Colors.Pink.Default,
            TertiaryDarken = Colors.Pink.Darken1,
            TertiaryLighten = Colors.Pink.Lighten1
        }
    };
}
