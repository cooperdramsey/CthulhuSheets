@if (DiceRollService.GroupHistory.Count > 0)
{
    <div class="dice-stack" aria-live="polite" role="status">
        @foreach (var group in DiceRollService.GroupHistory)
        {
            <div class="dice-chip @(group.Success == true ? "dice-chip-success" : group.Success == false ? "dice-chip-failure" : "")">
                <strong>@group.Total</strong>
                <span class="dice-chip-meta">@group.Expression</span>
            </div>
        }
    </div>
}

@if (_menuOpen)
{
    <div class="dice-dock" aria-label="Dice options">
        @foreach (var sides in DiceSides)
        {
            <MudBadge Content="@_selectedCounts.GetValueOrDefault(sides)"
                      Visible="@(_selectedCounts.ContainsKey(sides))"
                      Color="Color.Secondary" Overlap="true">
                <div @oncontextmenu="() => RemoveDie(sides)" @oncontextmenu:preventDefault>
                    <MudFab Size="Size.Small" Color="Color.Primary" Label="@($"d{sides}")"
                            Class="dice-option" OnClick="() => AddDie(sides)" />
                </div>
            </MudBadge>
        }
    </div>
}

<div class="dice-fab">
    <MudFab Color="Color.Primary"
            StartIcon="@(_menuOpen ? Icons.Material.Filled.PlayArrow : Icons.Material.Filled.Casino)"
            OnClick="OnFabClick" />
</div>
