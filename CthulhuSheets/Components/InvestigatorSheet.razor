<div class="sheet-container">
    <aside class="sheet-sidebar">
        <div class="sidebar-identity">
            <MudText Typo="Typo.h6">@Investigator.Name</MudText>
            @if (!string.IsNullOrWhiteSpace(Investigator.Occupation))
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">@Investigator.Occupation</MudText>
            }
        </div>

        <label for="@_portraitInputId" class="portrait-box">
            @if (!string.IsNullOrEmpty(Investigator.PortraitDataUrl))
            {
                <img src="@Investigator.PortraitDataUrl" class="portrait-image" alt="Portrait" />
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.Person" Class="portrait-icon" />
            }
            <InputFile id="@_portraitInputId" OnChange="HandlePortraitUpload" accept="image/*" style="display:none" />
        </label>

        <div class="sidebar-pools">
            <div class="pool-item">
                <MudText Typo="Typo.overline">Hit Points</MudText>
                <div class="pool-inputs">
                    <MudNumericField T="int?"
                                     @bind-Value="Investigator.HitPoints.Current"
                                     @bind-Value:after="PersistAsync"
                                     Placeholder="Cur"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="true"
                                     Class="pool-input" />
                    <span class="pool-sep">/</span>
                    <MudNumericField T="int?"
                                     @bind-Value="Investigator.HitPoints.Max"
                                     @bind-Value:after="PersistAsync"
                                     Placeholder="Max"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="true"
                                     Class="pool-input" />
                </div>
            </div>
            <div class="pool-item">
                <MudText Typo="Typo.overline">Magic Points</MudText>
                <div class="pool-inputs">
                    <MudNumericField T="int?"
                                     @bind-Value="Investigator.MagicPoints.Current"
                                     @bind-Value:after="PersistAsync"
                                     Placeholder="Cur"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="true"
                                     Class="pool-input" />
                    <span class="pool-sep">/</span>
                    <MudNumericField T="int?"
                                     @bind-Value="Investigator.MagicPoints.Max"
                                     @bind-Value:after="PersistAsync"
                                     Placeholder="Max"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="true"
                                     Class="pool-input" />
                </div>
            </div>
            <div class="pool-item">
                <MudText Typo="Typo.overline">Sanity</MudText>
                <div class="pool-inputs">
                    <MudNumericField T="int?"
                                     @bind-Value="Investigator.Sanity.Current"
                                     @bind-Value:after="PersistAsync"
                                     Placeholder="Cur"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="true"
                                     Class="pool-input" />
                    <span class="pool-sep">/</span>
                    <MudNumericField T="int?"
                                     @bind-Value="Investigator.Sanity.Max"
                                     @bind-Value:after="PersistAsync"
                                     Placeholder="Max"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="true"
                                     Class="pool-input" />
                </div>
            </div>
            <div class="pool-item">
                <MudText Typo="Typo.overline">Luck</MudText>
                <MudNumericField T="int?"
                                 @bind-Value="Investigator.Luck.Current"
                                 @bind-Value:after="PersistAsync"
                                 Placeholder="Current"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 HideSpinButtons="true" />
            </div>
        </div>

        <MudDivider />

        <div class="sidebar-conditions">
            <MudText Typo="Typo.overline">Conditions</MudText>
            <div class="condition-list">
                <MudCheckBox @bind-Value="Investigator.TemporaryInsanity"
                             @bind-Value:after="PersistAsync"
                             Label="Temp. Insanity"
                             Color="Color.Error"
                             Size="Size.Small" />
                <MudCheckBox @bind-Value="Investigator.IndefiniteInsanity"
                             @bind-Value:after="PersistAsync"
                             Label="Indef. Insanity"
                             Color="Color.Error"
                             Size="Size.Small" />
                <MudCheckBox @bind-Value="Investigator.MajorWound"
                             @bind-Value:after="PersistAsync"
                             Label="Major Wound"
                             Color="Color.Error"
                             Size="Size.Small" />
                <MudCheckBox @bind-Value="Investigator.Unconscious"
                             @bind-Value:after="PersistAsync"
                             Label="Unconscious"
                             Color="Color.Error"
                             Size="Size.Small" />
                <MudCheckBox @bind-Value="Investigator.Dying"
                             @bind-Value:after="PersistAsync"
                             Label="Dying"
                             Color="Color.Error"
                             Size="Size.Small" />
            </div>
        </div>

        <MudDivider />

        <div class="sidebar-stats">
            <MudText Typo="Typo.overline">Other Stats</MudText>
            <div class="stat-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Movement Rate</MudText>
                <MudText Typo="Typo.body2">@(Investigator.MovementRate ?? 0)</MudText>
            </div>
            <div class="stat-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Build</MudText>
                <MudText Typo="Typo.body2">@(Investigator.Build ?? 0)</MudText>
            </div>
            <div class="stat-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Damage Bonus</MudText>
                <MudText Typo="Typo.body2">@(Investigator.DamageBonus ?? 0)</MudText>
            </div>
        </div>
    </aside>

    <div class="sheet-main">
        <nav class="tab-rail" aria-label="Character sheet sections">
            @foreach (var tab in Tabs)
            {
                <button class="tab-button @(_activeTab == tab ? "active" : "")"
                        @onclick="() => _activeTab = tab"
                        aria-selected="@(_activeTab == tab)">
                    @tab
                </button>
            }
        </nav>

        <div class="tab-content" role="tabpanel">
            @switch (_activeTab)
            {
                case "Stats":
                    <div class="char-grid">
                        @foreach (var (label, stat) in CharacteristicList)
                        {
                            <MudCard Elevation="1" Class="char-card">
                                <MudCardContent Class="char-card-content">
                                    <div class="char-header">
                                        <div class="char-title-row">
                                            <div></div>
                                            <MudText Typo="Typo.h4" Class="char-abbr">@stat.Name</MudText>
                                            <div class="char-title-actions">
                                                <MudTooltip Text="Roll d100">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Casino"
                                                                   Size="Size.Small"
                                                                   Color="Color.Primary"
                                                                   OnClick="() => RollStat(stat)" />
                                                </MudTooltip>
                                                @if (_lastRolls.TryGetValue(stat.Name, out var lastRoll))
                                                {
                                                    <span class="char-roll-result">@lastRoll</span>
                                                }
                                            </div>
                                        </div>
                                        <MudText Typo="Typo.overline" Color="Color.Secondary">@label</MudText>
                                    </div>
                                    <MudDivider Class="my-2" />
                                    <div class="char-value-row">
                                        <span class="char-value-label">Regular</span>
                                        <span class="char-value-right">
                                            <span class="char-value-num">@(stat.Regular?.ToString() ?? "—")</span>
                                            @if (CheckIcon(stat.Name, stat.Regular) is { } regIcon)
                                            {
                                                <MudIcon Icon="@regIcon" Color="@CheckColor(stat.Name, stat.Regular)" Size="Size.Small" Class="char-check-icon" />
                                            }
                                        </span>
                                    </div>
                                    <div class="char-value-row">
                                        <span class="char-value-label">Half</span>
                                        <span class="char-value-right">
                                            <span class="char-value-num">@(stat.Half?.ToString() ?? "—")</span>
                                            @if (CheckIcon(stat.Name, stat.Half) is { } halfIcon)
                                            {
                                                <MudIcon Icon="@halfIcon" Color="@CheckColor(stat.Name, stat.Half)" Size="Size.Small" Class="char-check-icon" />
                                            }
                                        </span>
                                    </div>
                                    <div class="char-value-row">
                                        <span class="char-value-label">Fifth</span>
                                        <span class="char-value-right">
                                            <span class="char-value-num">@(stat.Fifth?.ToString() ?? "—")</span>
                                            @if (CheckIcon(stat.Name, stat.Fifth) is { } fifthIcon)
                                            {
                                                <MudIcon Icon="@fifthIcon" Color="@CheckColor(stat.Name, stat.Fifth)" Size="Size.Small" Class="char-check-icon" />
                                            }
                                        </span>
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        }
                    </div>
                    break;
                case "Skills":
                    <MudText Color="Color.Secondary">Skills content coming soon.</MudText>
                    break;
                case "Combat":
                    <div class="combat-container">
                        <div class="combat-stats-bar">
                            <div class="combat-stat-chip">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Build</MudText>
                                <MudText Typo="Typo.h5" Class="combat-stat-value">@(Investigator.Build?.ToString() ?? "—")</MudText>
                            </div>
                            <div class="combat-stat-chip">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Damage Bonus</MudText>
                                <MudText Typo="Typo.h5" Class="combat-stat-value">@(Investigator.DamageBonus?.ToString() ?? "—")</MudText>
                            </div>
                            <div class="combat-stat-chip">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Move</MudText>
                                <MudText Typo="Typo.h5" Class="combat-stat-value">@(Investigator.MovementRate?.ToString() ?? "—")</MudText>
                            </div>
                            <div class="combat-stat-chip combat-stat-chip--dodge">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Dodge</MudText>
                                <div class="combat-dodge-row">
                                    <div class="combat-dodge-tier">
                                        <span class="combat-dodge-num">@(DodgeRegular?.ToString() ?? "—")</span>
                                        <span class="combat-dodge-label">Reg</span>
                                    </div>
                                    <span class="combat-dodge-sep">/</span>
                                    <div class="combat-dodge-tier">
                                        <span class="combat-dodge-num">@(DodgeHard?.ToString() ?? "—")</span>
                                        <span class="combat-dodge-label">Hard</span>
                                    </div>
                                    <span class="combat-dodge-sep">/</span>
                                    <div class="combat-dodge-tier">
                                        <span class="combat-dodge-num">@(DodgeExtreme?.ToString() ?? "—")</span>
                                        <span class="combat-dodge-label">Ext</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="combat-weapons-section">
                            <div class="combat-weapons-header">
                                <MudText Typo="Typo.h6">Weapons</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Add"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               OnClick="AddWeapon" />
                            </div>
                            @if (Investigator.Weapons.Count > 0)
                            {
                                <div class="weapon-grid">
                                    <span class="weapon-col-header">Name</span>
                                    <span class="weapon-col-header">Damage</span>
                                    <span class="weapon-col-header">Atk/Rnd</span>
                                    <span class="weapon-col-header">Range</span>
                                    <span class="weapon-col-header">Ammo</span>
                                    <span class="weapon-col-header">Malf</span>
                                    <span></span>
                                    @foreach (var weapon in Investigator.Weapons)
                                    {
                                        <MudTextField @bind-Value="weapon.Name"
                                                      @bind-Value:after="PersistAsync"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Placeholder="Name" />
                                        <MudTextField @bind-Value="weapon.Damage"
                                                      @bind-Value:after="PersistAsync"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Placeholder="e.g. 1d6+db" />
                                        <MudNumericField T="int?"
                                                         @bind-Value="weapon.NumberOfAttacks"
                                                         @bind-Value:after="PersistAsync"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         HideSpinButtons="true" />
                                        <MudTextField @bind-Value="weapon.Range"
                                                      @bind-Value:after="PersistAsync"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Placeholder="e.g. Touch" />
                                        <MudNumericField T="int?"
                                                         @bind-Value="weapon.Ammo"
                                                         @bind-Value:after="PersistAsync"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         HideSpinButtons="true" />
                                        <MudNumericField T="int?"
                                                         @bind-Value="weapon.Malfunction"
                                                         @bind-Value:after="PersistAsync"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         HideSpinButtons="true" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Color="Color.Error"
                                                       Size="Size.Small"
                                                       OnClick="() => RemoveWeapon(weapon)" />
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    break;
                case "Items":
                    <div class="items-container">
                        <div class="items-text-fields">
                            <MudTextField @bind-Value="Investigator.TreasuredPossessions"
                                          @bind-Value:after="PersistAsync"
                                          Label="Treasured Possessions"
                                          Variant="Variant.Outlined"
                                          Lines="4" />
                            <MudTextField @bind-Value="Investigator.ArcaneTomesSpells"
                                          @bind-Value:after="PersistAsync"
                                          Label="Arcane Tomes & Spells"
                                          Variant="Variant.Outlined"
                                          Lines="4" />
                        </div>
                        <div class="items-gear-section">
                            <div class="items-gear-header">
                                <MudText Typo="Typo.h6">Gear & Possessions</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Add"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               OnClick="AddGearItem" />
                            </div>
                            @for (int i = 0; i < Investigator.GearAndPossessions.Count; i++)
                            {
                                var index = i;
                                <div class="asset-row">
                                    <MudTextField Value="Investigator.GearAndPossessions[index]"
                                                  ValueChanged="async (string v) => { Investigator.GearAndPossessions[index] = v; await PersistAsync(); }"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Placeholder="Item"
                                                  Class="asset-field" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="() => RemoveGearItem(index)" />
                                </div>
                            }
                        </div>
                    </div>
                    break;
                case "Wealth":
                    <div class="wealth-container">
                        <div class="wealth-stats">
                            <MudNumericField T="int?"
                                             @bind-Value="Investigator.Wealth.SpendingLevel"
                                             @bind-Value:after="PersistAsync"
                                             Label="Spending Level"
                                             Variant="Variant.Outlined"
                                             HideSpinButtons="true" />
                            <MudNumericField T="int?"
                                             @bind-Value="Investigator.Wealth.Cash"
                                             @bind-Value:after="PersistAsync"
                                             Label="Cash"
                                             Variant="Variant.Outlined"
                                             HideSpinButtons="true" />
                        </div>
                        <div class="wealth-assets-section">
                            <div class="wealth-assets-header">
                                <MudText Typo="Typo.h6">Assets</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Add"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               OnClick="AddAsset" />
                            </div>
                            @for (int i = 0; i < Investigator.Wealth.Assets.Count; i++)
                            {
                                var index = i;
                                <div class="asset-row">
                                    <MudTextField Value="Investigator.Wealth.Assets[index]"
                                                  ValueChanged="async (string v) => { Investigator.Wealth.Assets[index] = v; await PersistAsync(); }"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Placeholder="Asset"
                                                  Class="asset-field" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="() => RemoveAsset(index)" />
                                </div>
                            }
                        </div>
                    </div>
                    break;
                case "Info":
                    <div class="info-grid">
                        <MudTextField @bind-Value="Investigator.MyStory"
                                      @bind-Value:after="PersistAsync"
                                      Label="My Story"
                                      Variant="Variant.Outlined"
                                      Lines="4" />
                        <MudTextField @bind-Value="Investigator.PersonalDescription"
                                      @bind-Value:after="PersistAsync"
                                      Label="Personal Description"
                                      Variant="Variant.Outlined"
                                      Lines="4" />
                        <MudTextField @bind-Value="Investigator.IdeologyBeliefs"
                                      @bind-Value:after="PersistAsync"
                                      Label="Ideology & Beliefs"
                                      Variant="Variant.Outlined"
                                      Lines="4" />
                        <MudTextField @bind-Value="Investigator.SignificantPeople"
                                      @bind-Value:after="PersistAsync"
                                      Label="Significant People"
                                      Variant="Variant.Outlined"
                                      Lines="4" />
                        <MudTextField @bind-Value="Investigator.MeaningfulLocations"
                                      @bind-Value:after="PersistAsync"
                                      Label="Meaningful Locations"
                                      Variant="Variant.Outlined"
                                      Lines="4" />
                        <MudTextField @bind-Value="Investigator.Traits"
                                      @bind-Value:after="PersistAsync"
                                      Label="Traits"
                                      Variant="Variant.Outlined"
                                      Lines="4" />
                        <MudTextField @bind-Value="Investigator.InjuriesScars"
                                      @bind-Value:after="PersistAsync"
                                      Label="Injuries & Scars"
                                      Variant="Variant.Outlined"
                                      Lines="4" />
                        <MudTextField @bind-Value="Investigator.PhobiasManias"
                                      @bind-Value:after="PersistAsync"
                                      Label="Phobias & Manias"
                                      Variant="Variant.Outlined"
                                      Lines="4" />
                        <MudTextField @bind-Value="Investigator.EncountersWithTheMythos"
                                      @bind-Value:after="PersistAsync"
                                      Label="Encounters with the Mythos"
                                      Variant="Variant.Outlined"
                                      Lines="4"
                                      Class="info-full-width" />
                    </div>
                    <div class="fellow-investigators-section">
                        <div class="fellow-header">
                            <MudText Typo="Typo.h6">Fellow Investigators</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.PersonAdd"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           OnClick="AddFellowInvestigator" />
                        </div>
                        @foreach (var fellow in Investigator.FellowInvestigators)
                        {
                            <MudCard Elevation="1">
                                <MudCardContent Class="fellow-card-content">
                                    <div class="fellow-fields">
                                        <MudTextField @bind-Value="fellow.CharacterName"
                                                      @bind-Value:after="PersistAsync"
                                                      Label="Character Name"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense" />
                                        <MudTextField @bind-Value="fellow.PlayerName"
                                                      @bind-Value:after="PersistAsync"
                                                      Label="Player Name"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Color="Color.Error"
                                                       Size="Size.Small"
                                                       OnClick="() => RemoveFellowInvestigator(fellow)" />
                                        <MudTextField @bind-Value="fellow.Notes"
                                                      @bind-Value:after="PersistAsync"
                                                      Label="Notes"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Lines="2"
                                                      Class="fellow-notes" />
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        }
                    </div>
                    break;
            }
        </div>
    </div>
</div>